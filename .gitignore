# ========================================
# .gitignore - Empreendedores Exponenciais CSM
# ========================================
# Este arquivo evita que dados sensíveis
# e arquivos desnecessários sejam commitados
# ========================================

# CREDENCIAIS E ARQUIVOS SENSÍVEIS
.env
.env.local
.env.production
*.key
*.pem

# CONFIGURAÇÕES DE IDE
.vscode/
.idea/
*.swp
*.swo
*~

# ARQUIVOS DE SISTEMA
.DS_Store
Thumbs.db
desktop.ini

# LOGS E TEMPORÁRIOS
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# BUILD E DIST
dist/
build/
out/

# NODE MODULES (se usar npm no futuro)
node_modules/
package-lock.json
yarn.lock

# DADOS DE TESTE (se contiver dados reais de alunos)
dados-teste-*.json
*.sql.backup

# BACKUPS LOCAIS
*.bak
*.backup

# ARQUIVOS GRANDES
*.zip
*.tar.gz
*.sql.gz

# SUPABASE - NÃO COMMITAR ARQUIVOS COM CREDENCIAIS
# Se criar arquivos .env para Supabase, eles serão ignorados
